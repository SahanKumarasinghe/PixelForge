<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/md_theme_inverseOnSurface"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">
        <ImageView
            android:id="@+id/cart_product_image"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:scaleType="centerCrop"
            android:background="#F0F0F0"
            android:src="@drawable/empty_profile_img" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="8dp">

            <TextView
                android:id="@+id/cart_product_title"
                android:layout_width="230dp"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="2"
                android:text="Product Name"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/cart_product_price"
                android:layout_width="230dp"
                android:layout_height="wrap_content"
                android:text="$0.00"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="@font/aldrich"
                android:layout_marginTop="4dp" />
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:padding="4dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/cart_product_quantity_minus"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="?selectableItemBackgroundBorderless"
                    app:iconGravity="textStart"
                    app:iconPadding="3dp"
                    app:icon="@drawable/minus_circle_svgrepo_com"
                    app:iconSize="30dp" />

                <TextView
                    android:id="@+id/cart_product_quantity"
                    android:layout_width="40dp"
                    android:layout_height="32dp"
                    android:padding="7dp"
                    android:textAlignment="center"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:text="1"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/cart_product_quantity_plus"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    app:iconPadding="3dp"
                    android:background="?selectableItemBackgroundBorderless"
                    app:iconGravity="textEnd"
                    app:icon="@drawable/add_circle_svgrepo_com"
                    app:iconSize="30dp" />

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <ImageView
                android:id="@+id/cart_product_remove"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:src="@drawable/trash_bin_trash_svgrepo_com"
                android:padding="6dp"
                android:background="?selectableItemBackgroundBorderless"
                android:layout_marginBottom="8dp"
                android:clickable="true"/>

            <TextView
                android:id="@+id/cart_product_total_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$0.00"
                android:textSize="18sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>